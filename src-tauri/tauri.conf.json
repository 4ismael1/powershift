{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PowerShift",
  "version": "1.1.0",
  "identifier": "com.powershift.desktop",
  "build": {
    "beforeDevCommand": "npm run tauri:before-dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run tauri:before-build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "PowerShift",
        "width": 958,
        "height": 598,
        "minWidth": 860,
        "minHeight": 520,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#090d0d",
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "freezePrototype": true,
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'self'"
      },
      "devCsp": {
        "default-src": "'self' http://localhost:1420",
        "connect-src": "'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "script-src": "'self' 'unsafe-eval' http://localhost:1420",
        "style-src": "'self' 'unsafe-inline' http://localhost:1420"
      }
    }
  },
  "bundle": {
    "active": true,
    "publisher": "4ismael1",
    "copyright": "Copyright (c) 2026 4ismael1",
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../target/release/powershift-agent.exe": "powershift-agent.exe",
      "../target/release/powershift-tray.exe": "powershift-tray.exe"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "nsis/powershift-hooks.nsh",
        "languages": ["Spanish"]
      }
    }
  }
}
