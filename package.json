{
  "name": "powershift",
  "private": true,
  "version": "1.0.0",
  "author": "4ismael1",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/4ismael1/powershift.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:frontend && npm run build:agent:release && npm run build:tray:release",
    "build:frontend": "vue-tsc --noEmit && vite build",
    "build:agent:debug": "cargo build -p powershift-agent",
    "build:agent:release": "cargo build -p powershift-agent --release",
    "build:tray:debug": "cargo build -p powershift-tray",
    "build:tray:release": "cargo build -p powershift-tray --release",
    "prepare:native": "npm run build:agent:release && npm run build:tray:release",
    "lint:rust": "npm run prepare:native && cargo clippy --workspace --all-targets -- -D warnings",
    "test": "vitest run",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:before-dev": "npm run build:agent:release && npm run build:tray:release && npm run dev",
    "tauri:before-build": "npm run build",
    "tauri:dev": "tauri dev"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.4",
    "@types/node": "^22.20.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.1.10"
  }
}
